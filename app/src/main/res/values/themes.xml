<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme using Material Components.
         This is required for components like CardView and modern Buttons. -->
    <style name="Base.Theme.LostAndFoundApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryVariant">#3700B3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">#000000</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="Theme.LostAndFoundApp" parent="Base.Theme.LostAndFoundApp" />
</resources>
